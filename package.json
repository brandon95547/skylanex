{
  "name": "my-new-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "My New AI — personal AI software studio / agency site (static).",
  "scripts": {
    "build:html": "node build.mjs",
    "build:css": "tailwindcss -i ./src/styles/app.css -o ./dist/css/app.css --minify",
    "build": "npm run build:html && npm run build:css",
    "watch:css": "tailwindcss -i ./src/styles/app.css -o ./dist/css/app.css --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "tailwindcss": "^4.3.2"
  }
}
